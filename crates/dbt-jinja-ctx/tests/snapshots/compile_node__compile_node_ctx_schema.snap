{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompileNodeCtx",
  "description": "Per-node compile-time overlay layered onto [`CompileBaseCtx`] for each node SQL render. Today's `build_compile_node_context_inner<T>` populates this 1:1 тАФ same field-key strings (including the underscore-decorated `__minijinja_current_path` / `__minijinja_current_span` / `__dbt_current_execution_phase__` constants).\n\nAt construction, the calling renderer first builds `CompileBaseCtx`, then overlays a `CompileNodeCtx` on top. Several keys (`config`, `ref`, `source`, `function`, `builtins`, `context`) are intentionally re-emitted on the overlay тАФ they shadow the base entries with validated per-node variants. Today's code uses `BTreeMap::insert(...)` to overlay; after migration, callers `.extend(...)` the typed overlay onto the typed base before rendering.\n\nAll Object-typed slots are typed [`MinijinjaValue`] for the same reasons as [`crate::ResolveModelCtx`]: their concrete impls live in `dbt-jinja-utils` / `dbt-adapter`, and `model` / `builtins` are constructed via `Value::from_object(BTreeMap<String, MinijinjaValue>)` which downstream code downcasts.",
  "type": "object",
  "required": [
    "TARGET_PACKAGE_NAME",
    "TARGET_UNIQUE_ID",
    "__dbt_current_execution_phase__",
    "__minijinja_current_path",
    "__minijinja_current_span",
    "builtins",
    "config",
    "context",
    "database",
    "function",
    "identifier",
    "load_result",
    "model",
    "ref",
    "schema",
    "source",
    "store_raw_result",
    "store_result",
    "this"
  ],
  "properties": {
    "TARGET_PACKAGE_NAME": {
      "description": "`{{ TARGET_PACKAGE_NAME }}` тАФ node's package name (NOT root project's; shadows [`CompileBaseCtx::target_package_name`] which is the local project at base-build time).",
      "type": "string"
    },
    "TARGET_UNIQUE_ID": {
      "description": "`{{ TARGET_UNIQUE_ID }}` тАФ node's `<package>.<name>` identifier. Key string matches `minijinja::constants::TARGET_UNIQUE_ID`.",
      "type": "string"
    },
    "__dbt_current_execution_phase__": {
      "description": "`{{ __dbt_current_execution_phase__ }}` тАФ `\"render\"` at compile. Key string matches `minijinja::constants::CURRENT_EXECUTION_PHASE`.",
      "type": "string"
    },
    "__minijinja_current_path": {
      "description": "`{{ __minijinja_current_path }}` тАФ display path of the rendering `.sql` file. Key string matches `minijinja::constants::CURRENT_PATH`.",
      "type": "string"
    },
    "__minijinja_current_span": {
      "description": "`{{ __minijinja_current_span }}` тАФ span at the start of rendering (typically `minijinja::machinery::Span::default()`). Key string matches `minijinja::constants::CURRENT_SPAN`."
    },
    "builtins": {
      "description": "`{{ builtins.* }}` тАФ the per-node overlay map carrying the validated `ref` / `source` / `function` / `config` for downstream code that reads `builtins.config` directly. Shadows [`CompileBaseCtx::builtins`]. Same downcast contract as [`crate::ResolveModelCtx::builtins`] тАФ the underlying Object MUST be `BTreeMap<String, MinijinjaValue>` so `compile_node_context_inner` can `.downcast_ref::<...>()` it on the next per-node pass."
    },
    "config": {
      "description": "`{{ config(...) }}` тАФ `CompileConfig` Object backed by the node's validated, dot-walkable config map. Shadows [`CompileBaseCtx::config`] (`DummyConfig`)."
    },
    "context": {
      "description": "`{{ context }}` тАФ `MacroLookupContext` keyed by root project name. Shadows [`CompileBaseCtx::context`].",
      "allOf": [
        {
          "$ref": "#/definitions/JinjaObject<dbt_jinja_ctx::objects::lookup::MacroLookupContext>"
        }
      ]
    },
    "database": {
      "description": "`{{ database }}` тАФ model's adapter database.",
      "type": "string"
    },
    "function": {
      "description": "`{{ function(...) }}` тАФ `FunctionFunction` Object **with validation**. Shadows [`CompileBaseCtx::function`]."
    },
    "identifier": {
      "description": "`{{ identifier }}` тАФ model's adapter alias (NOT name; alias is the truncated form that fits OS path limits).",
      "type": "string"
    },
    "load_result": {
      "description": "`{{ load_result(...) }}` тАФ `ResultStore`-backed closure."
    },
    "model": {
      "description": "`{{ model.* }}` тАФ model dict serialized via `convert_yml_to_value_map(model.serialize())` plus a `batch` entry (today's parse-time stub uses London-1970 datetimes; replaced by the real microbatch context at run time)."
    },
    "ref": {
      "description": "`{{ ref(...) }}` тАФ `RefFunction` Object **with validation**. Shadows [`CompileBaseCtx::ref_fn`] (unvalidated)."
    },
    "schema": {
      "description": "`{{ schema }}` тАФ model's adapter schema.",
      "type": "string"
    },
    "source": {
      "description": "`{{ source(...) }}` тАФ `SourceFunction` Object **with validation**. Shadows [`CompileBaseCtx::source`]."
    },
    "store_raw_result": {
      "description": "`{{ store_raw_result(...) }}` тАФ `ResultStore`-backed closure."
    },
    "store_result": {
      "description": "`{{ store_result(...) }}` тАФ `ResultStore`-backed closure."
    },
    "this": {
      "description": "`{{ this }}` тАФ `RelationObject` Object (or deferred-relation `RelationObject` for unsafe nodes with deferred state available)."
    }
  },
  "definitions": {
    "JinjaObject<dbt_jinja_ctx::objects::lookup::MacroLookupContext>": {
      "description": "Opaque Jinja-callable object backed by `dbt_jinja_ctx::objects::lookup::MacroLookupContext`.",
      "type": "object",
      "x-jinja-object": true,
      "x-jinja-object-type": "dbt_jinja_ctx::objects::lookup::MacroLookupContext"
    }
  }
}

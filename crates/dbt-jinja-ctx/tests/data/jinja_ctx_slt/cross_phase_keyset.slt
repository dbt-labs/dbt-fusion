# Per-model identifiers + path/span markers — resolve_model only.
key TARGET_UNIQUE_ID
----
load              <absent>
resolve_globals   <absent>
resolve_base      <absent>
resolve_model     my_project.dbt_columns
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

# `model` is `from_object(BTreeMap<String, MinijinjaValue>)`. Dot-walk into
# it returns the inner entries — covered exhaustively by
# resolve_model_basics.slt and the `model_downcasts_to_btreemap_string_value`
# Rust regression test.
key model.name
----
load              <absent>
resolve_globals   <absent>
resolve_base      <absent>
resolve_model     dbt_columns
compile_base      <skip>
compile_node      <skip>
run_node          <skip>

# `builtins` is the per-model overlay map of ref/source/function/config
# values. Compile/run-node code downcasts this to BTreeMap<String, Value>.
key builtins.ref
----
load              <absent>
resolve_globals   <absent>
resolve_base      <absent>
resolve_model     ref-fn-stub
compile_base      <skip>
compile_node      <skip>
run_node          <skip>
